<% content_for :title, spanish? ? "Proyectos - Angel Mora" : "Projects - Angel Mora" %>
<%# BRAND artifact: Technical Grid register; mono metadata, display project titles; amber only on hovered links. %>

<section class="border-b border-black bg-white py-16 dark:border-white dark:bg-black sm:py-24">
  <div class="brand-container brand-grid">
    <div class="lg:col-span-3">
      <span class="brand-section-marker"><span class="brand-section-marker__number">01</span> <%= spanish? ? "Proyectos" : "Projects" %></span>
    </div>
    <div class="lg:col-span-8 lg:col-start-5">
      <p class="brand-kicker"><%= spanish? ? "Filosofia / tecnocritica / codigo" : "Philosophy / technocritique / code" %></p>
      <h1 class="mt-5 max-w-4xl font-display text-5xl font-bold leading-none tracking-[-0.05em] text-black dark:text-white sm:text-7xl">
        <%= spanish? ? "Cosas en la interseccion entre filosofia, tecnocritica y codigo." : "Things in the intersection of philosophy, technocritique and code." %>
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-400">
        <%= spanish? ? "Sistemas pequenos, experimentos e interfaces de investigacion que convierten texto en infraestructura." : "Small systems, experiments, and research interfaces that turn text into infrastructure." %>
      </p>
    </div>
  </div>
</section>

<section class="bg-white py-16 dark:bg-black sm:py-24">
  <div class="brand-container brand-grid">
    <div class="lg:col-span-3">
      <p class="brand-kicker"><%= spanish? ? "Trabajo seleccionado" : "Selected work" %></p>
    </div>
    <div class="lg:col-span-9">
      <ul role="list" class="grid border-l border-t border-black dark:border-white sm:grid-cols-2 lg:grid-cols-3">
        <% @projects.each_with_index do |project, index| %>
          <li class="border-b border-r border-black dark:border-white">
            <article class="flex min-h-full flex-col p-6">
              <div class="flex items-center justify-between gap-4">
                <span class="flex h-12 w-12 items-center justify-center border border-black font-mono text-sm font-semibold uppercase tracking-[0.1em] text-black dark:border-white dark:text-white">
                  <%= project[:logo_initial] %>
                </span>
                <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-zinc-500 dark:text-zinc-400"><%= format("%02d", index + 1) %></span>
              </div>
              <h2 class="mt-7 font-display text-2xl font-bold tracking-[-0.035em] text-black dark:text-white">
                <%= link_to project[:name], project[:link], class: "hover:underline decoration-brand decoration-2 underline-offset-4" %>
              </h2>
              <p class="mt-3 text-sm leading-6 text-zinc-600 dark:text-zinc-400"><%= project[:description] %></p>
              <p class="mt-auto pt-8 font-mono text-[11px] uppercase tracking-[0.08em] text-zinc-500 dark:text-zinc-400">
                <%= project[:link].sub(%r{^https?://}, "") %>
              </p>
            </article>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</section>
