<!DOCTYPE html>
<html lang="en" class="h-full antialiased">
  <head>
    <title><%= content_for(:title) || "Angel Mora - Senior Rails Developer" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Lora:ital,wght@0,400;1,400&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      // Dark mode: check localStorage or system preference before render
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark')
      } else {
        document.documentElement.classList.remove('dark')
      }
    </script>
  </head>

  <body class="min-h-full bg-white dark:bg-black" data-controller="mobile-menu">
      <div class="relative flex min-h-screen w-full flex-col">
        <%= render "shared/header" %>
        <main class="flex-auto">
          <% if notice %>
            <div class="container-outer"><div class="container-inner"><div class="mx-auto max-w-2xl lg:max-w-5xl mt-6">
              <div class="border border-emerald-900 bg-emerald-100 p-3 text-sm text-emerald-950"><%= notice %></div>
            </div></div></div>
          <% end %>
          <% if alert %>
            <div class="container-outer"><div class="container-inner"><div class="mx-auto max-w-2xl lg:max-w-5xl mt-6">
              <div class="border border-red-900 bg-red-100 p-3 text-sm text-red-950"><%= alert %></div>
            </div></div></div>
          <% end %>
          <%= yield %>
        </main>
        <%= render "shared/footer" %>
      </div>
  </body>
</html>
