<%= render ContainerComponent.new(class: "mt-24 md:mt-28") do |c| %>
  <div class="mx-auto grid max-w-xl grid-cols-1 gap-y-20 lg:max-w-none lg:grid-cols-2">
    <div class="flex flex-col gap-16">
      <% @articles.each do |article| %>
        <article class="group relative flex flex-col items-start">
          <div class="absolute -inset-x-4 -inset-y-6 z-0 scale-95 bg-zinc-50 opacity-0 transition group-hover:scale-100 group-hover:opacity-100 dark:bg-zinc-800/50 sm:-inset-x-6 sm:rounded-2xl"></div>
          <div class="relative z-10 order-first mb-3 w-full">
            <img
              src="<%= article[:image] %>"
              alt=""
              class="aspect-[16/9] w-full rounded-2xl bg-zinc-100 object-cover dark:bg-zinc-800 sm:aspect-[2/1] lg:aspect-[3/2]"
              loading="lazy"
            />
            <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-zinc-900/10 dark:ring-zinc-100/10"></div>
          </div>
          <%= render Card::EyebrowComponent.new(as: "time", datetime: article[:date], decorate: true) { Date.parse(article[:date]).strftime("%B %-d, %Y") } %>
          <h2 class="text-base font-semibold tracking-tight text-zinc-800 dark:text-zinc-100">
            <%= link_to article_path(article[:slug]) do %>
              <span class="absolute -inset-x-4 -inset-y-6 z-20 sm:-inset-x-6 sm:rounded-2xl"></span>
              <span class="relative z-10"><%= article[:title] %></span>
            <% end %>
          </h2>
          <p class="relative z-10 mt-2 text-sm text-zinc-600 dark:text-zinc-400"><%= article[:description] %></p>
          <div class="relative z-10 mt-4 flex items-center text-sm font-medium text-teal-500">
            Read article
            <svg viewBox="0 0 16 16" fill="none" class="ml-1 h-4 w-4 stroke-current"><path d="M6.75 5.75 9.25 8l-2.5 2.25" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </article>
      <% end %>
    </div>
    <div class="space-y-10 lg:pl-16 xl:pl-24">
      <%= render NewsletterComponent.new %>
      <%= render ResumeComponent.new %>
    </div>
  </div>
<% end %>