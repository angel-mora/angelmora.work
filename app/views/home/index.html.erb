<% content_for :title, spanish? ? "Angel Mora - Desarrollador Senior Ruby on Rails" : "Angel Mora - Senior Ruby on Rails Developer" %>

<%
  achievements = if spanish?
    [
      ["40% menos tiempo de carga", "Turbo Frames con lazy loading", "Inktavo / Printavo"],
      ["Suite de tests 45 -> 38 min", "Profiling con TestProf", "Info-Tech Research Group"],
      ["Elimine N+1 queries O(n) -> O(1)", "rutas criticas de produccion", nil],
      ["120 hrs/mes ahorradas", "30+ tareas Rake de automatizacion", "SEPROBAN"],
      ["200K+ registros georreferenciados", "PostGIS + Leaflet.js", nil]
    ]
  else
    [
      ["40% page load reduction", "Turbo Frames lazy loading", "Inktavo / Printavo"],
      ["Test suite 45 -> 38 min", "TestProf profiling", "Info-Tech Research Group"],
      ["Eliminated N+1 queries O(n) -> O(1)", "critical production paths", nil],
      ["120 hrs/month saved", "30+ Rake automation tasks", "SEPROBAN"],
      ["Georeferenced 200K+ records", "PostGIS + Leaflet.js", nil]
    ]
  end

  stats = if spanish?
    [["6+", "Anos Rails"], ["4", "Empresas"], ["5-8", "Versiones Rails"], ["CST", "Zona horaria"]]
  else
    [["6+", "Yrs Rails"], ["4", "Companies"], ["5-8", "Rails versions"], ["CST", "Timezone"]]
  end

  stack = [
    ["Ruby", "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/ruby/ruby-original.svg"],
    ["Rails", "https://cdn.simpleicons.org/rubyonrails/CC0000"],
    ["PostgreSQL", "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/postgresql/postgresql-original.svg"],
    ["Redis", "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/redis/redis-original.svg"],
    ["Hotwire", "https://cdn.simpleicons.org/hotwire/FBBF24"],
    ["Sidekiq", "https://cdn.simpleicons.org/sidekiq/B1003E"],
    ["Docker", "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg"],
    ["AWS", "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/amazonwebservices/amazonwebservices-original-wordmark.svg"],
    ["GraphQL", "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/graphql/graphql-plain.svg"],
    ["React", "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original.svg"],
    ["PostGIS", "https://postgis.net/brand.svg"],
    ["RSpec", "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/rspec/rspec-original.svg"]
  ]

  contacts = [
    ["LinkedIn", "in/angelmoradev", "https://linkedin.com/in/angelmoradev", "in"],
    ["GitHub", "angel-mora", "https://github.com/angel-mora", "gh"],
    ["Email", "angelmomaa", "mailto:angelmomaa@gmail.com", "@"]
  ]
%>

<section class="portfolio-hero">
  <div class="portfolio-hero__main">
    <div>
      <span class="portfolio-neon"></span>
      <div class="flex flex-wrap gap-2">
        <span class="portfolio-status"><span></span><%= spanish? ? "Disponible - Contratista remoto - UTC-6" : "Available - Remote contractor - UTC-6" %></span>
        <span class="portfolio-tag">Ruby on Rails &amp; Hotwire</span>
      </div>
    </div>

    <div>
      <h1 class="portfolio-title">Angel Mora<span>.</span></h1>
      <p class="portfolio-subtitle">
        <%= spanish? ? "Desarrollador Senior Rails / AI Product Engineer / Ciudad de Mexico" : "Senior Rails Developer / AI Product Engineer / Mexico City" %>
      </p>
    </div>

    <p class="portfolio-bio">
      <%= spanish? ? "6+ anos enviando monolitos Rails a produccion: Hotwire, background jobs, PostgreSQL a escala e integraciones con agentes de AI. Me importa el diseno tanto como la arquitectura backend; ultimamente construyo productos de AI y paso mucho tiempo en producto e interfaz." : "6+ years shipping production Rails monoliths: Hotwire, background jobs, PostgreSQL at scale, and AI-agent integrations. I care about design as much as backend architecture; lately I build AI products and spend a lot of time on product/interface design." %>
    </p>

    <div class="portfolio-actions">
      <%= link_to spanish? ? "Ver CV PDF" : "View PDF CV", "/angel_mora_cv.pdf", class: "brand-button brand-button--brand", target: "_blank", rel: "noopener" %>
      <button class="brand-button brand-button--outline" type="button" data-action="booking-modal#open" data-booking-modal-type-param="recruiter"><%= spanish? ? "Intro reclutamiento" : "Recruiter intro" %></button>
      <button class="brand-button brand-button--outline" type="button" data-action="booking-modal#open" data-booking-modal-type-param="consulting"><%= spanish? ? "Llamada consultoria" : "Consulting call" %></button>
    </div>

    <div class="portfolio-achievements" aria-label="Key achievements">
      <% achievements.each do |headline, method, company| %>
        <div class="portfolio-achievement">
          <span class="portfolio-achievement__arrow">&nearr;</span>
          <p>
            <strong><%= headline %></strong>
            <span><%= method %><% if company.present? %> &middot; <%= company %><% end %></span>
          </p>
        </div>
      <% end %>
    </div>

    <div class="portfolio-stats">
      <% stats.each do |value, label| %>
        <div>
          <strong><%= value %></strong>
          <span><%= label %></span>
        </div>
      <% end %>
    </div>
  </div>

  <aside class="portfolio-hero__side">
    <div>
      <p class="portfolio-label"><%= spanish? ? "Stack central" : "Core stack" %></p>
      <div class="portfolio-stack">
        <% stack.each do |name, icon_url| %>
          <div class="portfolio-tech" title="<%= name %>">
            <img src="<%= icon_url %>" alt="" class="portfolio-tech__icon <%= "portfolio-tech__icon--wide" if ["AWS", "PostGIS"].include?(name) %>" loading="lazy">
            <span><%= name %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div>
      <p class="portfolio-label"><%= spanish? ? "Contacto" : "Contact" %></p>
      <div class="portfolio-contact">
        <% contacts.each do |label, username, href, logo| %>
          <%= link_to href, aria: { label: label }, target: (href.start_with?("http") ? "_blank" : nil), rel: (href.start_with?("http") ? "noopener" : nil) do %>
            <span class="portfolio-contact__logo"><%= logo %></span>
            <span><%= username %></span>
          <% end %>
        <% end %>
      </div>
    </div>
  </aside>
</section>
