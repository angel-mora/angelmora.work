<% content_for :title, "Angel Mora - Senior Ruby on Rails Developer" %>

<%
  wins = [
    ["40%", "page load reduction", "Turbo Frames lazy loading at Inktavo / Printavo"],
    ["45 -> 38", "test suite minutes", "TestProf profiling at Info-Tech Research Group"],
    ["O(n) -> O(1)", "query paths", "N+1 removal on production flows"],
    ["120", "hrs/month saved", "30+ Rake automation tasks at SEPROBAN"],
    ["200K+", "records", "PostGIS and Leaflet.js intelligence tooling"]
  ]

  roles = [
    ["Inktavo / Printavo", "Senior Rails Developer", "Sep 2024 - Jul 2025"],
    ["Info-Tech Research Group", "Rails Developer", "Dec 2021 - Sep 2024"],
    ["Aleph Risk Intelligence", "Backend Developer", "Oct 2021 - Dec 2021"],
    ["SEPROBAN", "Rails Developer / Intelligence Analyst", "Oct 2019 - Sep 2021"]
  ]

  stack = ["Ruby", "Rails", "PostgreSQL", "Redis", "Sidekiq", "Hotwire", "Docker", "AWS", "GraphQL", "React", "PostGIS", "RSpec"]

  contacts = [
    ["LinkedIn", "linkedin.com/in/angelmoradev", "https://linkedin.com/in/angelmoradev"],
    ["GitHub", "github.com/angel-mora", "https://github.com/angel-mora"],
    ["Email", "angelmomaa@gmail.com", "mailto:angelmomaa@gmail.com"]
  ]
%>

<section class="brand-container py-8 sm:py-10">
  <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px] xl:grid-cols-[minmax(0,1fr)_400px]">
    <div class="brand-card p-5 sm:p-6 lg:p-7">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="brand-section-marker">
          <span class="brand-section-marker__number">01</span>
          <span>Portfolio</span>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="brand-tag brand-tag--success">Available - Remote - UTC-6</span>
          <span class="brand-tag brand-tag--info">Rails - Hotwire - Jobs</span>
        </div>
      </div>

      <div class="mt-6 grid gap-5 lg:grid-cols-[2px_minmax(0,1fr)]">
        <div class="hidden bg-brand lg:block"></div>
        <div>
          <h1 class="max-w-4xl font-display text-4xl font-bold leading-[0.96] tracking-[-0.045em] text-black dark:text-white sm:text-5xl lg:text-6xl xl:text-7xl">
            Angel Mora.<br>
            Senior Ruby on Rails Developer.
          </h1>

          <p class="mt-5 max-w-3xl text-base leading-7 text-zinc-700 dark:text-zinc-300">
            6+ years shipping production Rails monoliths: background jobs, Hotwire UX, PostgreSQL at scale, and AI-agent integrations. Philosophy background, CS graduate work, and strong product judgment.
          </p>

          <div class="mt-6 flex flex-wrap gap-3">
            <%= link_to "Download CV", "/angel_mora_cv.pdf", class: "brand-button brand-button--brand", download: true %>
            <%= link_to "Recruiter intro", "https://calendly.com/angel-mora", class: "brand-button brand-button--outline" %>
            <%= link_to "Consulting call", "mailto:angelmomaa@gmail.com?subject=Rails%20technical%20consultation", class: "brand-button brand-button--outline" %>
          </div>
        </div>
      </div>

      <div class="mt-7 grid grid-cols-2 border border-black dark:border-white sm:grid-cols-4">
        <div class="border-b border-r border-black p-3 dark:border-white sm:border-b-0">
          <div class="font-mono text-2xl font-semibold tracking-[-0.04em] text-black dark:text-white">6+</div>
          <div class="mt-1 font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-500">Years Rails</div>
        </div>
        <div class="border-b border-black p-3 dark:border-white sm:border-b-0 sm:border-r">
          <div class="font-mono text-2xl font-semibold tracking-[-0.04em] text-black dark:text-white">4</div>
          <div class="mt-1 font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-500">Companies</div>
        </div>
        <div class="border-r border-black p-3 dark:border-white sm:border-r">
          <div class="font-mono text-2xl font-semibold tracking-[-0.04em] text-black dark:text-white">5-8</div>
          <div class="mt-1 font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-500">Rails versions</div>
        </div>
        <div class="p-3">
          <div class="font-mono text-2xl font-semibold tracking-[-0.04em] text-black dark:text-white">CST</div>
          <div class="mt-1 font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-500">Timezone</div>
        </div>
      </div>

      <div class="mt-5 grid grid-cols-2 gap-3 xl:grid-cols-5">
        <% wins.each do |metric, label, context| %>
          <article class="brand-panel p-3">
            <div class="font-mono text-lg font-semibold tracking-[-0.04em] text-black dark:text-white"><%= metric %></div>
            <h2 class="mt-2 text-xs font-semibold uppercase tracking-[0.03em] text-black dark:text-white"><%= label %></h2>
            <p class="mt-1 text-xs leading-5 text-zinc-600 dark:text-zinc-400"><%= context %></p>
          </article>
        <% end %>
      </div>
    </div>

    <aside class="grid gap-4">
      <div class="brand-panel p-5">
        <p class="brand-kicker">Work modes</p>
        <div class="mt-4 grid gap-3">
          <%= link_to "https://calendly.com/angel-mora", class: "brand-card block p-4 transition hover:bg-zinc-100 dark:hover:bg-zinc-900" do %>
            <div class="brand-kicker">Recruiter intro</div>
            <div class="mt-2 text-lg font-semibold text-black dark:text-white">30 min - Free</div>
            <p class="mt-1 text-xs leading-5 text-zinc-600 dark:text-zinc-400">Role fit, compensation, timeline, and availability.</p>
          <% end %>

          <%= link_to "mailto:angelmomaa@gmail.com?subject=Rails%20technical%20consultation", class: "brand-card block p-4 transition hover:bg-zinc-100 dark:hover:bg-zinc-900" do %>
            <div class="brand-kicker">Consulting client</div>
            <div class="mt-2 text-lg font-semibold text-black dark:text-white">60 min - Paid</div>
            <p class="mt-1 text-xs leading-5 text-zinc-600 dark:text-zinc-400">Rails architecture, performance, Sidekiq, Hotwire, AI systems.</p>
          <% end %>
        </div>
      </div>

      <div class="brand-card p-5">
        <p class="brand-kicker">Contact</p>
        <div class="mt-3 space-y-2 text-sm">
          <% contacts.each do |label, value, href| %>
            <div class="grid grid-cols-[78px_minmax(0,1fr)] gap-3 border-t border-zinc-300 pt-2 dark:border-zinc-700">
              <dt class="font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-500"><%= label %></dt>
              <dd class="truncate"><%= link_to value, href, class: "text-black hover:underline decoration-brand decoration-2 underline-offset-4 dark:text-white" %></dd>
            </div>
          <% end %>
        </div>
      </div>

      <div class="brand-card p-5">
        <p class="brand-kicker">Core stack</p>
        <div class="mt-3 flex flex-wrap gap-2">
          <% stack.each do |tool| %>
            <span class="border border-zinc-300 px-2 py-1 font-mono text-[10px] font-semibold uppercase tracking-[0.1em] text-zinc-700 dark:border-zinc-700 dark:text-zinc-300"><%= tool %></span>
          <% end %>
        </div>
      </div>
    </aside>
  </div>
</section>

<section class="brand-container border-t border-black py-8 dark:border-white lg:py-10" id="about">
  <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px] xl:grid-cols-[minmax(0,1fr)_400px]">
    <div class="brand-card p-5">
      <div class="flex items-center justify-between gap-4">
        <div class="brand-section-marker">
          <span class="brand-section-marker__number">02</span>
          <span>Experience</span>
        </div>
        <p class="brand-kicker hidden sm:block">Compact track record</p>
      </div>
      <div class="mt-4 overflow-x-auto">
        <table class="brand-table min-w-[640px]">
          <thead>
            <tr>
              <th>Company</th>
              <th>Role</th>
              <th>Period</th>
            </tr>
          </thead>
          <tbody>
            <% roles.each do |company, role, period| %>
              <tr>
                <td class="font-semibold text-black dark:text-white"><%= company %></td>
                <td><%= role %></td>
                <td class="font-mono text-xs uppercase tracking-[0.08em] text-zinc-500"><%= period %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="brand-panel p-5">
      <p class="brand-kicker">What you get</p>
      <h2 class="mt-3 font-display text-2xl font-semibold tracking-[-0.04em] text-black dark:text-white">Senior Rails execution without unnecessary architecture.</h2>
      <p class="mt-3 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
        I prefer monoliths over microservices, spec-driven development, and operational simplicity. Useful for teams that need production Rails work, performance cleanup, or technical judgment before building.
      </p>
      <div class="mt-4 grid gap-2 text-sm sm:grid-cols-2 lg:grid-cols-1">
        <div class="border-t border-zinc-300 pt-2 dark:border-zinc-700">
          <span class="brand-kicker">Education</span>
          <p class="mt-1 text-black dark:text-white">B.A. Philosophy - UNAM</p>
          <p class="text-zinc-500">M.S. CS &amp; Telecom - UTEL</p>
        </div>
        <div class="border-t border-zinc-300 pt-2 dark:border-zinc-700">
          <span class="brand-kicker">Artifact</span>
          <p class="mt-1 text-black dark:text-white">Gallery Space + Technical Grid</p>
          <p class="text-zinc-500">Amber names CTA and neon trace only.</p>
        </div>
      </div>
    </div>
  </div>
</section>
