<% content_for :title, "Angel Mora - Senior Ruby on Rails Developer" %>

<%
  achievements = [
    ["40% page load reduction", "Turbo Frames lazy loading", "Inktavo / Printavo"],
    ["Test suite 45 -> 38 min", "TestProf profiling", "Info-Tech Research Group"],
    ["Eliminated N+1 queries O(n) -> O(1)", "critical production paths", nil],
    ["120 hrs/month saved", "30+ Rake automation tasks", "SEPROBAN"],
    ["Georeferenced 200K+ records", "PostGIS + Leaflet.js", nil]
  ]

  stats = [
    ["6+", "Yrs Rails"],
    ["4", "Companies"],
    ["5-8", "Rails versions"],
    ["CST", "Timezone"]
  ]

  stack = [
    ["Ruby", "RB", "#CC342D"],
    ["Rails", "RL", "#CC0000"],
    ["PostgreSQL", "PG", "#336791"],
    ["Redis", "RD", "#D82C20"],
    ["Hotwire", "HW", "#FBBF24"],
    ["Sidekiq", "SK", "#CC0000"],
    ["Docker", "DK", "#2496ED"],
    ["AWS", "AWS", "#FF9900"],
    ["GraphQL", "GQL", "#E10098"],
    ["React", "RCT", "#61DAFB"],
    ["PostGIS", "GIS", "#4169E1"],
    ["RSpec", "RSP", "#CC342D"]
  ]

  contacts = [
    ["LinkedIn", "in/angelmoradev", "https://linkedin.com/in/angelmoradev", "in"],
    ["GitHub", "angel-mora", "https://github.com/angel-mora", "gh"],
    ["Email", "angelmomaa", "mailto:angelmomaa@gmail.com", "@"]
  ]
%>

<section class="portfolio-hero">
  <div class="portfolio-hero__main">
    <div>
      <span class="portfolio-neon"></span>
      <div class="flex flex-wrap gap-2">
        <span class="portfolio-status"><span></span>Available - Remote contractor - UTC-6</span>
        <span class="portfolio-tag">Ruby on Rails &amp; Hotwire</span>
      </div>
    </div>

    <div>
      <h1 class="portfolio-title">Angel Mora<span>.</span></h1>
      <p class="portfolio-subtitle">
        Senior Rails Developer / AI Product Engineer / Mexico City
      </p>
    </div>

    <p class="portfolio-bio">
      6+ years shipping production Rails monoliths: Hotwire, background jobs, PostgreSQL at scale, and AI-agent integrations. I care about design as much as backend architecture; lately I build AI products and spend a lot of time on product/interface design.
    </p>

    <div class="portfolio-actions">
      <%= link_to "View PDF CV", "/angel_mora_cv.pdf", class: "brand-button brand-button--brand", target: "_blank", rel: "noopener" %>
      <button class="brand-button brand-button--outline" type="button" data-action="booking-modal#open" data-booking-modal-type-param="recruiter">Recruiter intro</button>
      <button class="brand-button brand-button--outline" type="button" data-action="booking-modal#open" data-booking-modal-type-param="consulting">Consulting call</button>
    </div>

    <div class="portfolio-achievements" aria-label="Key achievements">
      <% achievements.each do |headline, method, company| %>
        <div class="portfolio-achievement">
          <span class="portfolio-achievement__arrow">&nearr;</span>
          <p>
            <strong><%= headline %></strong>
            <span><%= method %><% if company.present? %> &middot; <%= company %><% end %></span>
          </p>
        </div>
      <% end %>
    </div>

    <div class="portfolio-stats">
      <% stats.each do |value, label| %>
        <div>
          <strong><%= value %></strong>
          <span><%= label %></span>
        </div>
      <% end %>
    </div>
  </div>

  <aside class="portfolio-hero__side">
    <div>
      <p class="portfolio-label">Core stack</p>
      <div class="portfolio-stack">
        <% stack.each do |name, abbreviation, color| %>
          <div class="portfolio-tech" title="<%= name %>">
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <rect width="32" height="32" fill="<%= color %>"></rect>
              <text x="16" y="19" text-anchor="middle"><%= abbreviation %></text>
            </svg>
            <span><%= name %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div>
      <p class="portfolio-label">Contact</p>
      <div class="portfolio-contact">
        <% contacts.each do |label, username, href, logo| %>
          <%= link_to href, aria: { label: label }, target: (href.start_with?("http") ? "_blank" : nil), rel: (href.start_with?("http") ? "noopener" : nil) do %>
            <span class="portfolio-contact__logo"><%= logo %></span>
            <span><%= username %></span>
          <% end %>
        <% end %>
      </div>
    </div>
  </aside>
</section>
