<%= render ContainerComponent.new(class: "mt-16 sm:mt-32") do %>
  <div class="max-w-sm mx-auto">
    <h1 class="text-4xl font-bold tracking-tight text-zinc-800 dark:text-zinc-100 sm:text-5xl">Sign up</h1>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-8 space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-zinc-700 dark:text-zinc-300" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full appearance-none rounded-md border border-zinc-900/10 bg-white px-3 py-2 shadow-md shadow-zinc-800/5 placeholder:text-zinc-400 focus:border-teal-500 focus:outline-none focus:ring-4 focus:ring-teal-500/10 dark:border-zinc-700 dark:bg-zinc-700/[0.15] dark:text-zinc-200 dark:placeholder:text-zinc-500 dark:focus:border-teal-400 dark:focus:ring-teal-400/10 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-zinc-700 dark:text-zinc-300" %>
        <% if @minimum_password_length %>
          <span class="text-xs text-zinc-400 dark:text-zinc-500">(<%= @minimum_password_length %> characters minimum)</span>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 block w-full appearance-none rounded-md border border-zinc-900/10 bg-white px-3 py-2 shadow-md shadow-zinc-800/5 placeholder:text-zinc-400 focus:border-teal-500 focus:outline-none focus:ring-4 focus:ring-teal-500/10 dark:border-zinc-700 dark:bg-zinc-700/[0.15] dark:text-zinc-200 dark:placeholder:text-zinc-500 dark:focus:border-teal-400 dark:focus:ring-teal-400/10 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-zinc-700 dark:text-zinc-300" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 block w-full appearance-none rounded-md border border-zinc-900/10 bg-white px-3 py-2 shadow-md shadow-zinc-800/5 placeholder:text-zinc-400 focus:border-teal-500 focus:outline-none focus:ring-4 focus:ring-teal-500/10 dark:border-zinc-700 dark:bg-zinc-700/[0.15] dark:text-zinc-200 dark:placeholder:text-zinc-500 dark:focus:border-teal-400 dark:focus:ring-teal-400/10 sm:text-sm" %>
      </div>

      <div>
        <%= f.submit "Sign up", class: "w-full inline-flex items-center justify-center rounded-md py-2 px-3 text-sm font-semibold bg-zinc-800 text-zinc-100 hover:bg-zinc-700 active:bg-zinc-800 dark:bg-zinc-700 dark:hover:bg-zinc-600 transition" %>
      </div>
    <% end %>

    <div class="mt-6 text-center text-sm text-zinc-500 dark:text-zinc-400">
      <%= render "devise/shared/links" %>
    </div>
  </div>
<% end %>
