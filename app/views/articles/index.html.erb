<%= render SimpleLayoutComponent.new(title: "Writing on software and knowledge base systems.", intro: "A showcase of my best articles over the years.") do %>
  <div class="md:border-l md:border-zinc-100 md:pl-6 md:dark:border-zinc-700/40">
    <div class="flex max-w-3xl flex-col space-y-16">
      <% @articles.each do |article| %>
        <article class="md:grid md:grid-cols-4 md:items-baseline">
          <%= render CardComponent.new(class: "md:col-span-3") do %>
            <div class="absolute -inset-x-4 -inset-y-6 z-0 scale-95 bg-zinc-50 opacity-0 transition group-hover:scale-100 group-hover:opacity-100 dark:bg-zinc-800/50 sm:-inset-x-6 sm:rounded-2xl"></div>
            <%= render Card::EyebrowComponent.new(as: "time", datetime: article[:date], decorate: true, class: "md:hidden") { Date.parse(article[:date]).strftime("%B %-d, %Y") } %>
            <h2 class="text-base font-semibold tracking-tight text-zinc-800 dark:text-zinc-100">
              <%= link_to article[:title], article_path(article[:slug]), class: "relative z-10" %>
            </h2>
            <p class="relative z-10 mt-2 text-sm text-zinc-600 dark:text-zinc-400"><%= article[:description] %></p>
            <div class="relative z-10 mt-4 flex items-center text-sm font-medium text-teal-500">
              Read article
              <svg viewBox="0 0 16 16" fill="none" class="ml-1 h-4 w-4 stroke-current"><path d="M6.75 5.75 9.25 8l-2.5 2.25" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span class="absolute -inset-x-4 -inset-y-6 z-20 sm:-inset-x-6 sm:rounded-2xl"></span>
          <% end %>
          <%= render Card::EyebrowComponent.new(as: "time", datetime: article[:date], class: "mt-1 hidden md:block") { Date.parse(article[:date]).strftime("%B %-d, %Y") } %>
        </article>
      <% end %>
    </div>
  </div>
<% end %>