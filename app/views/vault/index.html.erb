<%= render ContainerComponent.new(class: "mt-16 sm:mt-32") do %>
  <div class="max-w-2xl">
    <h1 class="text-4xl font-bold tracking-tight text-zinc-800 dark:text-zinc-100 sm:text-5xl">
      My Second Brain
    </h1>
    <p class="mt-6 text-base text-zinc-600 dark:text-zinc-400">
      This is my personal knowledge vault — powered by Quartz and wrapped in Rails.
      Browse my notes, ideas, and connections across domains.
    </p>
  </div>

  <div class="mt-16 sm:mt-20">
    <div class="rounded-2xl border border-zinc-100 p-6 dark:border-zinc-700/40">
      <h2 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">
        Quartz Vault
      </h2>
      <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
        The vault content is served by Quartz. This Rails app acts as the paywall and dispatcher,
        gradually replacing Quartz features with Hotwire as the product evolves.
      </p>
      <div class="mt-6">
        <div data-controller="quartz-embed" data-quartz-embed-url-value="<%= ENV.fetch("QUARTZ_URL", "http://localhost:8080") %>" class="w-full rounded-xl overflow-hidden border border-zinc-200 dark:border-zinc-700">
          <div class="bg-zinc-100 dark:bg-zinc-800 px-4 py-2 flex items-center gap-2 border-b border-zinc-200 dark:border-zinc-700">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
            </div>
            <div class="flex-1 text-center">
              <span class="text-xs text-zinc-500 dark:text-zinc-400 font-mono" data-quartz-embed-target="status">Connecting to Quartz...</span>
            </div>
          </div>
          <iframe
            data-quartz-embed-target="iframe"
            src="<%= ENV.fetch("QUARTZ_URL", "http://localhost:8080") %>"
            class="w-full border-0"
            style="height: 75vh; min-height: 600px;"
            loading="lazy"
            title="Quartz Knowledge Vault"
            sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
<% end %>