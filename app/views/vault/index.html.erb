<% content_for :title, "Vault - Angel Mora" %>
<%# BRAND artifact: Technical Grid register; iframe is treated as infrastructure, not a browser decoration. %>

<section class="border-b border-black bg-white py-16 dark:border-white dark:bg-black sm:py-24">
  <div class="brand-container brand-grid">
    <div class="lg:col-span-3">
      <span class="brand-section-marker"><span class="brand-section-marker__number">01</span> Vault</span>
    </div>
    <div class="lg:col-span-8 lg:col-start-5">
      <p class="brand-kicker">Quartz / Rails / knowledge base</p>
      <h1 class="mt-5 max-w-4xl font-display text-5xl font-bold leading-none tracking-[-0.05em] text-black dark:text-white sm:text-7xl">
        My Second Brain.
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-7 text-zinc-600 dark:text-zinc-400">
        A personal knowledge vault powered by Quartz and wrapped in Rails. Notes, ideas, and connections across domains.
      </p>
    </div>
  </div>
</section>

<section class="bg-white py-16 dark:bg-black sm:py-24">
  <div class="brand-container brand-grid">
    <div class="lg:col-span-3">
      <p class="brand-kicker">Embedded system</p>
    </div>
    <div class="lg:col-span-9">
      <div class="brand-panel">
        <header class="grid gap-4 border-b border-black p-5 dark:border-white sm:grid-cols-[1fr_auto] sm:items-center">
          <div>
            <h2 class="font-display text-2xl font-bold tracking-[-0.035em] text-black dark:text-white">Quartz Vault</h2>
            <p class="mt-2 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
              Rails acts as the paywall and dispatcher while Quartz serves the knowledge graph.
            </p>
          </div>
          <span class="brand-tag brand-tag--info">Iframe / live</span>
        </header>

        <div data-controller="quartz-embed" data-quartz-embed-url-value="<%= ENV.fetch("QUARTZ_URL", "http://localhost:8080") %>" class="w-full">
          <div class="flex items-center justify-between gap-4 border-b border-black bg-white px-4 py-3 dark:border-white dark:bg-black">
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-500 dark:text-zinc-400">Connection</span>
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-500 dark:text-zinc-400" data-quartz-embed-target="status">Connecting to Quartz...</span>
          </div>
          <iframe
            data-quartz-embed-target="iframe"
            src="<%= ENV.fetch("QUARTZ_URL", "http://localhost:8080") %>"
            class="w-full border-0"
            style="height: 75vh; min-height: 600px;"
            loading="lazy"
            title="Quartz Knowledge Vault"
            sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
