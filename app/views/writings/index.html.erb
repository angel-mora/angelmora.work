<% content_for :title, spanish? ? "Escritura - Angel Mora" : "Writing - Angel Mora" %>
<%# BRAND artifact: Gallery Space register; Space Grotesk + Lora carry hierarchy; amber names CTA; the cover reproduces the inverted book artifact. %>

<%
  purchase_body = if spanish?
  <<~TEXT
    Hola Angel,

    Quiero recibir Lee Esto Para Hacer Un Cambio Real por email por $50 USD.

    Por favor enviame instrucciones de pago y detalles de entrega.
  TEXT
  else
  <<~TEXT
    Hi Angel,

    I want to receive Read This To Make A Real Change by email for $50 USD.

    Please send payment instructions and delivery details.
  TEXT
  end

  section_links = [
    ["01", spanish? ? "Posicion" : "Position", "#position"],
    ["02", spanish? ? "Hub lector" : "Reader hub", "#reader-hub"],
    ["03", spanish? ? "Formatos" : "Formats", "#formats"],
    ["04", spanish? ? "Compra" : "Purchase", "#receive"]
  ]
%>

<div class="pb-24 sm:pb-20">
<section class="border-b border-black bg-white dark:border-white dark:bg-black">
  <div class="brand-container grid min-h-[calc(100vh-57px)] gap-8 py-8 sm:py-10 lg:grid-cols-12 lg:items-center lg:gap-10 lg:py-12">
    <div class="order-2 lg:order-1 lg:col-span-6">
      <div class="mx-auto w-full max-w-[540px] bg-[#6B6B6B] p-3 sm:p-4">
        <article class="grid aspect-[528/816] grid-cols-[42px_1fr] overflow-hidden bg-black text-white shadow-[6px_6px_0_0_#EF4444]">
          <aside class="relative flex items-center justify-center border-r border-[#1C1C1C]">
            <div class="absolute left-0 top-0 h-full w-[3px] bg-[#EF4444]"></div>
            <span class="whitespace-nowrap font-mono text-[10px] uppercase tracking-[0.12em] text-[#404040]" style="writing-mode: vertical-rl; transform: rotate(180deg);">
              LEE ESTO PARA HACER UN CAMBIO REAL
            </span>
          </aside>
          <div class="flex flex-col px-4 sm:px-6">
            <div class="flex flex-1 flex-col justify-center py-4">
              <span class="block font-display text-[clamp(2.9rem,10vw,4.55rem)] font-bold uppercase leading-[0.93] tracking-[-0.04em] text-white">LEE ESTO</span>
              <span class="block font-display text-[clamp(2.9rem,10vw,4.55rem)] font-bold uppercase leading-[0.93] tracking-[-0.04em] text-white">PARA</span>
              <span class="block font-display text-[clamp(2.9rem,10vw,4.55rem)] font-bold uppercase leading-[0.93] tracking-[-0.04em] text-white">HACER UN</span>
              <span class="block font-display text-[clamp(2.9rem,10vw,4.55rem)] font-bold uppercase leading-[0.93] tracking-[-0.04em] text-white">CAMBIO</span>
              <div class="my-3 h-0.5 bg-[#EF4444]"></div>
              <span class="block font-display text-[clamp(6rem,24vw,10.75rem)] font-bold uppercase leading-[0.86] tracking-[-0.045em] text-[#EF4444]">REAL</span>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.09em] text-[#484848]"><%= spanish? ? "y otros textos" : "and other texts" %></p>
            </div>
            <div class="flex items-end justify-between border-t border-[#252525] py-4">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-white">Angel de Jesus</p>
              <p class="text-right font-mono text-[10px] uppercase leading-5 tracking-[0.09em] text-[#484848]">La Partida</p>
            </div>
          </div>
        </article>
      </div>
    </div>

    <div class="order-1 flex flex-col justify-center lg:order-2 lg:col-span-6 lg:pl-6">
      <div class="mb-5 flex flex-wrap gap-2">
        <span class="brand-tag brand-tag--featured">Writing</span>
        <span class="brand-tag brand-tag--info">Reader hub</span>
      </div>
      <p class="brand-kicker"><%= spanish? ? "LEPHUCR / Correspondencia lectora" : "LEPHUCR / Reader correspondence" %></p>
      <h1 class="mt-4 max-w-3xl font-display text-4xl font-bold leading-[0.96] tracking-[-0.045em] text-black dark:text-white sm:text-5xl xl:text-6xl">
        <%= spanish? ? "Un libro para personas cansadas de confundir discurso con accion." : "A book for people tired of mistaking discourse for action." %>
      </h1>
      <p class="mt-5 max-w-2xl font-reading text-lg leading-8 text-zinc-700 dark:text-zinc-300">
        <%= spanish? ? "Un manuscrito vivo sobre vida publica, dominacion mercantil, organizacion critica y la distancia dolorosa entre querer cambio y construirlo. Lee primero; escribe despues si el objeto es para ti." : "A living manuscript about public life, mercantile domination, critical organization, and the painful distance between wanting change and building it. Read first, then write if the object is for you." %>
      </p>
      <div class="mt-7 flex flex-wrap items-center gap-4">
        <%= mail_to @purchase_email, spanish? ? "Recibir por email - $50 USD" : "Receive by email - $50 USD", subject: spanish? ? "Lee Esto Para Hacer Un Cambio Real - $50 USD" : "Read This To Make A Real Change - $50 USD", body: purchase_body, class: "brand-button brand-button--brand" %>
        <%= link_to spanish? ? "Explorar el hub lector" : "Explore the reader hub", "#reader-hub", class: "brand-button brand-button--outline" %>
      </div>
    </div>
  </div>
</section>

<section id="position" class="bg-white py-20 dark:bg-black sm:py-24">
  <div class="brand-container brand-grid">
    <div class="lg:col-span-3">
      <span class="brand-section-marker"><span class="brand-section-marker__number">01</span> <%= spanish? ? "Posicion" : "Position" %></span>
    </div>
    <div class="lg:col-span-8 lg:col-start-5">
      <p class="font-display text-4xl font-bold leading-tight tracking-[-0.04em] text-black dark:text-white sm:text-6xl">
        <%= spanish? ? "No es autoayuda. No es distancia academica. Una nota de campo para actuar despues de que la teoria ya hizo su dano." : "Not self-help. Not academic distance. A field note for action after theory has done its damage." %>
      </p>
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        <% @reader_modes.each do |title, description| %>
          <article class="brand-card p-5">
            <h2 class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-black dark:text-white"><%= title %></h2>
            <p class="mt-4 text-sm leading-6 text-zinc-600 dark:text-zinc-400"><%= description %></p>
          </article>
        <% end %>
      </div>
      <div class="mt-10 border-l-4 border-brand bg-zinc-100 p-6 dark:bg-zinc-950">
        <p class="font-reading text-xl leading-8 text-zinc-800 dark:text-zinc-200">
          <%= spanish? ? "Es necesario analizar la dominacion mercantil como proceso, flujo e historia." : "It is necessary to analyze mercantile domination as process, flow, and history." %>
        </p>
        <p class="mt-3 font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-500 dark:text-zinc-400"><%= spanish? ? "De la introduccion original de LEPHUCR" : "From the original LEPHUCR introduction" %></p>
      </div>
    </div>
  </div>
</section>

<section id="reader-hub" class="border-y border-black bg-zinc-50 py-20 dark:border-white dark:bg-zinc-950 sm:py-24">
  <div class="brand-container brand-grid">
    <div class="lg:col-span-3">
      <span class="brand-section-marker"><span class="brand-section-marker__number">02</span> <%= spanish? ? "Hub lector" : "Reader hub" %></span>
      <p class="mt-5 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
        <%= spanish? ? "Adaptado del indice de referencia y del lector Quartz activo en lephucr.com." : "Adapted from the reference table of contents and the live Quartz reader at lephucr.com." %>
      </p>
    </div>
    <div class="space-y-6 lg:col-span-8 lg:col-start-5">
      <% @reader_tracks.each do |track| %>
        <article class="brand-panel p-0">
          <header class="grid gap-4 border-b border-black p-5 dark:border-white sm:grid-cols-[auto_1fr_auto] sm:items-start">
            <span class="font-display text-5xl font-bold tracking-[-0.05em] text-black dark:text-white"><%= track[:number] %></span>
            <div>
              <h2 class="font-display text-2xl font-bold tracking-[-0.03em] text-black dark:text-white"><%= track[:title] %></h2>
              <p class="mt-2 text-sm leading-6 text-zinc-600 dark:text-zinc-400"><%= track[:note] %></p>
            </div>
            <span class="brand-tag <%= track[:chapters].any? { |chapter| chapter[:href].present? } ? "brand-tag--success" : "brand-tag--info" %>"><%= track[:status] %></span>
          </header>
          <ol class="divide-y divide-zinc-300 dark:divide-zinc-700">
            <% track[:chapters].each do |chapter| %>
              <li class="grid gap-3 px-5 py-4 sm:grid-cols-[1fr_auto] sm:items-center">
                <div>
                  <% if chapter[:href].present? %>
                    <%= link_to chapter[:title], chapter[:href], class: "text-sm font-semibold text-black underline decoration-brand decoration-2 underline-offset-4 dark:text-white", target: "_blank", rel: "noopener" %>
                  <% else %>
                    <span class="text-sm font-semibold text-black dark:text-white"><%= chapter[:title] %></span>
                  <% end %>
                </div>
                <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-zinc-500 dark:text-zinc-400"><%= spanish? ? "p." : "p." %> <%= chapter[:page] %></span>
              </li>
            <% end %>
          </ol>
        </article>
      <% end %>
    </div>
  </div>
</section>

<section id="formats" class="bg-white py-20 dark:bg-black sm:py-24">
  <div class="brand-container brand-grid">
    <div class="lg:col-span-3">
      <span class="brand-section-marker"><span class="brand-section-marker__number">03</span> <%= spanish? ? "Formatos" : "Formats" %></span>
    </div>
    <div class="lg:col-span-8 lg:col-start-5">
      <h2 class="font-display text-4xl font-bold tracking-[-0.04em] text-black dark:text-white sm:text-5xl">
        <%= spanish? ? "Un libro, pero tambien un pequeno sistema de distribucion." : "A book, but also a small distribution system." %>
      </h2>
      <div class="mt-10 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
        <figure class="brand-panel">
          <div class="grid gap-px border-b border-black bg-black dark:border-white md:grid-cols-2">
            <% ["book-image-0.png", "book-image-1.png", "book-image-2.png", "book-image-3.png"].each do |image| %>
              <img src="/lephucr/<%= image %>" alt="<%= spanish? ? "Vista del libro LEPHUCR" : "LEPHUCR book view" %>" class="aspect-[4/3] w-full bg-white object-cover" loading="lazy">
            <% end %>
          </div>
          <figcaption class="p-5 font-mono text-[10px] uppercase leading-5 tracking-[0.12em] text-zinc-500 dark:text-zinc-400">
            <%= spanish? ? "Imagenes del libro y del PDF de trabajo, no una maqueta generica." : "Images from the book and working PDF, not a generic mockup." %>
          </figcaption>
        </figure>
        <div class="grid border border-black dark:border-white md:grid-cols-2">
          <% @deliverables.each_with_index do |(title, description), index| %>
            <article class="border-b border-black p-6 dark:border-white md:border-r <%= index > 1 ? "md:border-b-0" : "" %> <%= index.odd? ? "md:border-r-0" : "" %>">
              <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-zinc-500 dark:text-zinc-400"><%= format("%02d", index + 1) %></p>
              <h3 class="mt-4 font-display text-2xl font-bold tracking-[-0.03em] text-black dark:text-white"><%= title %></h3>
              <p class="mt-3 text-sm leading-6 text-zinc-600 dark:text-zinc-400"><%= description %></p>
            </article>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="receive" class="border-t border-black bg-black py-20 text-white dark:border-white dark:bg-white dark:text-black sm:py-24">
  <div class="brand-container brand-grid">
    <div class="lg:col-span-3">
      <span class="brand-section-marker text-white dark:text-black"><span class="brand-section-marker__number border-white dark:border-black">04</span> <%= spanish? ? "Compra" : "Purchase" %></span>
    </div>
    <div class="lg:col-span-8 lg:col-start-5">
      <div class="grid gap-8 border border-white p-6 dark:border-black lg:grid-cols-[1fr_auto] lg:p-8">
        <div>
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-zinc-400 dark:text-zinc-600"><%= spanish? ? "Edicion por correspondencia" : "Correspondence edition" %></p>
          <h2 class="mt-4 max-w-2xl font-display text-4xl font-bold leading-tight tracking-[-0.045em] sm:text-6xl">
            <%= spanish? ? "Recibe el manuscrito por email por $50 USD." : "Receive the manuscript by email for $50 USD." %>
          </h2>
          <p class="mt-5 max-w-xl text-sm leading-7 text-zinc-300 dark:text-zinc-700">
            <%= spanish? ? "Sin funnel agresivo. Envia el email, recibe instrucciones de pago y despues el libro con notas de entrega. Si necesitas inspeccionar el trabajo primero, el hub lector esta abierto arriba." : "No aggressive funnel. Send the email, get payment instructions, receive the book and delivery notes directly. If you need to inspect the work first, the reader hub is open above." %>
          </p>
        </div>
        <div class="flex flex-col justify-between gap-6 border-t border-white pt-6 dark:border-black lg:min-w-60 lg:border-l lg:border-t-0 lg:pl-8 lg:pt-0">
          <div>
            <p class="font-display text-7xl font-bold tracking-[-0.06em]">$50</p>
            <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-zinc-400 dark:text-zinc-600"><%= spanish? ? "USD / entrega por email" : "USD / email delivery" %></p>
          </div>
          <%= mail_to @purchase_email, spanish? ? "Escribir para recibirlo" : "Write to receive it", subject: spanish? ? "Lee Esto Para Hacer Un Cambio Real - $50 USD" : "Read This To Make A Real Change - $50 USD", body: purchase_body, class: "brand-button brand-button--brand" %>
        </div>
      </div>
    </div>
  </div>
</section>
</div>

<nav aria-label="Writing page sections" class="fixed bottom-0 left-0 z-40 w-full border-t border-black bg-white dark:border-white dark:bg-black">
  <ol class="brand-container grid divide-y divide-black font-mono text-[10px] font-semibold uppercase tracking-[0.1em] dark:divide-white sm:grid-cols-4 sm:divide-x sm:divide-y-0 sm:text-[11px]">
    <% section_links.each do |number, label, href| %>
      <li>
        <%= link_to href, class: "flex items-center gap-3 px-3 py-3 text-black hover:bg-brand hover:text-black dark:text-white sm:px-4" do %>
          <span><%= number %></span>
          <span><%= label %></span>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>
