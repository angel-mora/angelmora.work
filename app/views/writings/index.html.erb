<% content_for :title, "Writing - Angel Mora" %>
<%# BRAND artifact: Gallery Space register; Space Grotesk + Lora carry hierarchy; amber names CTA and cover rule; neutrals are white/black/zinc with hard rules. %>

<%
  purchase_body = <<~TEXT
    Hi Angel,

    I want to receive Read This To Make A Real Change by email for $50 USD.

    Please send payment instructions and delivery details.
  TEXT

  section_links = [
    ["01", "Position", "#position"],
    ["02", "Reader hub", "#reader-hub"],
    ["03", "Formats", "#formats"],
    ["04", "$50 mail", "#receive"]
  ]
%>

<section class="border-b border-black bg-white dark:border-white dark:bg-black">
  <div class="brand-container grid min-h-[calc(100svh-57px)] gap-8 py-8 sm:py-10 lg:grid-cols-12 lg:items-center lg:gap-10 lg:py-12">
    <div class="order-2 lg:order-1 lg:col-span-6">
      <div class="mx-auto w-full max-w-[760px] border-2 border-black bg-zinc-200 p-3 dark:border-white dark:bg-zinc-900">
        <div class="grid min-h-[460px] border-2 border-black bg-white dark:border-white md:grid-cols-[0.82fr_1fr]">
          <aside class="hidden border-r-2 border-black bg-white md:flex md:flex-col dark:border-white">
            <div class="h-1 bg-brand"></div>
            <div class="flex flex-1 flex-col p-5">
              <p class="font-display text-[15px] font-semibold leading-snug tracking-[-0.02em] text-black">
                What are the possibilities of acting from a specific circumstance, in the most uncertain and absurd moment of history?
              </p>
              <div class="my-4 h-px bg-black"></div>
              <p class="text-[12px] leading-6 text-zinc-700">
                A technocritical position against the confusion between theory and action: state, markets, machines, apparatuses, capture, desire, organization.
              </p>
              <div class="my-4 h-px bg-black"></div>
              <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-black">This book</p>
              <ul class="mt-3 space-y-2 font-mono text-[10px] leading-5 text-zinc-700">
                <li>Introduces La Partida as a technocritical position</li>
                <li>Reads real change through state, capitalism, and markets</li>
                <li>Frames critical action beyond the theory-praxis split</li>
                <li>Maps apparatuses of capture and extraction</li>
              </ul>
              <div class="mt-auto flex items-end justify-between border-t border-zinc-300 pt-4">
                <div>
                  <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-black">La Partida</p>
                  <p class="font-mono text-[10px] uppercase tracking-[0.09em] text-zinc-500">Collection Apparatuses</p>
                </div>
                <div class="h-10 w-16 bg-[repeating-linear-gradient(90deg,#000_0_2px,transparent_2px_5px)]"></div>
              </div>
            </div>
          </aside>

          <article class="grid min-h-[460px] grid-cols-[44px_1fr] bg-white">
            <aside class="relative flex items-center justify-center border-r border-zinc-300">
              <div class="absolute left-0 top-0 h-full w-[3px] bg-brand"></div>
              <span class="whitespace-nowrap font-mono text-[10px] uppercase tracking-[0.12em] text-zinc-500" style="writing-mode: vertical-rl; transform: rotate(180deg);">
                LEPHUCR / Technocritique / Apparatuses / Vol. 01
              </span>
            </aside>
            <div class="flex flex-col px-4 py-5 sm:px-6">
              <div class="border-b-2 border-black pb-3">
                <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-zinc-500">Angel de Jesus / Read This To Make A Real Change</p>
              </div>
              <div class="flex flex-1 flex-col justify-center py-5">
                <span class="block font-display text-[clamp(2.4rem,7vw,4.8rem)] font-bold uppercase leading-[0.9] tracking-[-0.05em] text-black">Read this</span>
                <span class="block font-display text-[clamp(2.4rem,7vw,4.8rem)] font-bold uppercase leading-[0.9] tracking-[-0.05em] text-black">to make</span>
                <span class="block font-display text-[clamp(2.4rem,7vw,4.8rem)] font-bold uppercase leading-[0.9] tracking-[-0.05em] text-black">a real</span>
                <div class="my-4 h-1 bg-brand"></div>
                <span class="block font-display text-[clamp(5rem,15vw,10rem)] font-bold uppercase leading-[0.82] tracking-[-0.06em] text-brand">Change</span>
                <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.12em] text-zinc-500">and other texts</p>
              </div>
              <div class="flex items-end justify-between border-t-2 border-black pt-3">
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-black">Angel de Jesus</p>
                <p class="text-right font-mono text-[10px] uppercase leading-5 tracking-[0.09em] text-zinc-500">La Partida<br>Collection Apparatuses</p>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>

    <div class="order-1 flex flex-col justify-center lg:order-2 lg:col-span-6 lg:pl-6">
      <div class="mb-5 flex flex-wrap gap-2">
        <span class="brand-tag brand-tag--featured">Writing</span>
        <span class="brand-tag brand-tag--info">Reader hub</span>
      </div>
      <p class="brand-kicker">LEPHUCR / Reader correspondence</p>
      <h1 class="mt-4 max-w-3xl font-display text-4xl font-bold leading-[0.96] tracking-[-0.045em] text-black dark:text-white sm:text-5xl xl:text-6xl">
        A book for people tired of mistaking discourse for action.
      </h1>
      <p class="mt-5 max-w-2xl font-reading text-lg leading-8 text-zinc-700 dark:text-zinc-300">
        LEPHUCR is the acronym for <span class="font-semibold text-black dark:text-white">LEE ESTO PARA HACER UN CAMBIO REAL</span>. In English: <span class="font-semibold text-black dark:text-white">READ THIS TO MAKE A REAL CHANGE</span>.
      </p>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-zinc-600 dark:text-zinc-400">
        A living manuscript about public life, mercantile domination, critical organization, and the painful distance between wanting change and building it. Read first, then write if the object is for you.
      </p>
      <div class="mt-7 flex flex-wrap items-center gap-4">
        <%= mail_to @purchase_email, "Receive by email - $50 USD", subject: "Read This To Make A Real Change - $50 USD", body: purchase_body, class: "brand-button brand-button--brand" %>
        <%= link_to "Explore the reader hub", "#reader-hub", class: "brand-button brand-button--outline" %>
      </div>
    </div>
  </div>
</section>

<section id="position" class="bg-white py-20 dark:bg-black sm:py-24">
  <div class="brand-container brand-grid">
    <div class="lg:col-span-3">
      <span class="brand-section-marker"><span class="brand-section-marker__number">01</span> Position</span>
    </div>
    <div class="lg:col-span-8 lg:col-start-5">
      <p class="font-display text-4xl font-bold leading-tight tracking-[-0.04em] text-black dark:text-white sm:text-6xl">
        Not self-help. Not academic distance. A field note for action after theory has done its damage.
      </p>
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        <% @reader_modes.each do |title, description| %>
          <article class="brand-card p-5">
            <h2 class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-black dark:text-white"><%= title %></h2>
            <p class="mt-4 text-sm leading-6 text-zinc-600 dark:text-zinc-400"><%= description %></p>
          </article>
        <% end %>
      </div>
      <div class="mt-10 border-l-4 border-brand bg-zinc-100 p-6 dark:bg-zinc-950">
        <p class="font-reading text-xl leading-8 text-zinc-800 dark:text-zinc-200">
          "It is necessary to analyze mercantile domination as process, flow, and history."
        </p>
        <p class="mt-3 font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-zinc-500 dark:text-zinc-400">From the original LEPHUCR introduction</p>
      </div>
    </div>
  </div>
</section>

<section id="reader-hub" class="border-y border-black bg-zinc-50 py-20 dark:border-white dark:bg-zinc-950 sm:py-24">
  <div class="brand-container brand-grid">
    <div class="lg:col-span-3">
      <span class="brand-section-marker"><span class="brand-section-marker__number">02</span> Reader hub</span>
      <p class="mt-5 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
        Adapted from the reference table of contents and the live Quartz reader at lephucr.com.
      </p>
    </div>
    <div class="space-y-6 lg:col-span-8 lg:col-start-5">
      <% @reader_tracks.each do |track| %>
        <article class="brand-panel p-0">
          <header class="grid gap-4 border-b border-black p-5 dark:border-white sm:grid-cols-[auto_1fr_auto] sm:items-start">
            <span class="font-display text-5xl font-bold tracking-[-0.05em] text-black dark:text-white"><%= track[:number] %></span>
            <div>
              <h2 class="font-display text-2xl font-bold tracking-[-0.03em] text-black dark:text-white"><%= track[:title] %></h2>
              <p class="mt-2 text-sm leading-6 text-zinc-600 dark:text-zinc-400"><%= track[:note] %></p>
            </div>
            <span class="brand-tag <%= track[:status] == "Open hub" ? "brand-tag--success" : "brand-tag--info" %>"><%= track[:status] %></span>
          </header>
          <ol class="divide-y divide-zinc-300 dark:divide-zinc-700">
            <% track[:chapters].each do |chapter| %>
              <li class="grid gap-3 px-5 py-4 sm:grid-cols-[1fr_auto] sm:items-center">
                <div>
                  <% if chapter[:href].present? %>
                    <%= link_to chapter[:title], chapter[:href], class: "text-sm font-semibold text-black underline decoration-brand decoration-2 underline-offset-4 dark:text-white", target: "_blank", rel: "noopener" %>
                  <% else %>
                    <span class="text-sm font-semibold text-black dark:text-white"><%= chapter[:title] %></span>
                  <% end %>
                </div>
                <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-zinc-500 dark:text-zinc-400">p. <%= chapter[:page] %></span>
              </li>
            <% end %>
          </ol>
        </article>
      <% end %>
    </div>
  </div>
</section>

<section id="formats" class="bg-white py-20 dark:bg-black sm:py-24">
  <div class="brand-container brand-grid">
    <div class="lg:col-span-3">
      <span class="brand-section-marker"><span class="brand-section-marker__number">03</span> Formats</span>
    </div>
    <div class="lg:col-span-8 lg:col-start-5">
      <h2 class="font-display text-4xl font-bold tracking-[-0.04em] text-black dark:text-white sm:text-5xl">
        A book, but also a small distribution system.
      </h2>
      <div class="mt-10 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
        <figure class="brand-panel">
          <img src="https://lephucr.com/static/og-image.png" alt="LEPHUCR reader hub preview" class="aspect-[1200/630] w-full border-b border-black object-cover dark:border-white" loading="lazy">
          <figcaption class="p-5 font-mono text-[10px] uppercase leading-5 tracking-[0.12em] text-zinc-500 dark:text-zinc-400">
            Reader preview image from the live LEPHUCR publication system.
          </figcaption>
        </figure>
        <div class="grid border border-black dark:border-white md:grid-cols-2">
          <% @deliverables.each_with_index do |(title, description), index| %>
            <article class="border-b border-black p-6 dark:border-white md:border-r <%= index > 1 ? "md:border-b-0" : "" %> <%= index.odd? ? "md:border-r-0" : "" %>">
              <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-zinc-500 dark:text-zinc-400"><%= format("%02d", index + 1) %></p>
              <h3 class="mt-4 font-display text-2xl font-bold tracking-[-0.03em] text-black dark:text-white"><%= title %></h3>
              <p class="mt-3 text-sm leading-6 text-zinc-600 dark:text-zinc-400"><%= description %></p>
            </article>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="receive" class="border-t border-black bg-black py-20 text-white dark:border-white dark:bg-white dark:text-black sm:py-24">
  <div class="brand-container brand-grid">
    <div class="lg:col-span-3">
      <span class="brand-section-marker text-white dark:text-black"><span class="brand-section-marker__number border-white dark:border-black">04</span> Purchase</span>
    </div>
    <div class="lg:col-span-8 lg:col-start-5">
      <div class="grid gap-8 border border-white p-6 dark:border-black lg:grid-cols-[1fr_auto] lg:p-8">
        <div>
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-zinc-400 dark:text-zinc-600">Correspondence edition</p>
          <h2 class="mt-4 max-w-2xl font-display text-4xl font-bold leading-tight tracking-[-0.045em] sm:text-6xl">
            Receive the manuscript by email for $50 USD.
          </h2>
          <p class="mt-5 max-w-xl text-sm leading-7 text-zinc-300 dark:text-zinc-700">
            No aggressive funnel. Send the email, get payment instructions, receive the book and delivery notes directly. If you need to inspect the work first, the reader hub is open above.
          </p>
        </div>
        <div class="flex flex-col justify-between gap-6 border-t border-white pt-6 dark:border-black lg:min-w-60 lg:border-l lg:border-t-0 lg:pl-8 lg:pt-0">
          <div>
            <p class="font-display text-7xl font-bold tracking-[-0.06em]">$50</p>
            <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-zinc-400 dark:text-zinc-600">USD / email delivery</p>
          </div>
          <%= mail_to @purchase_email, "Write to receive it", subject: "Read This To Make A Real Change - $50 USD", body: purchase_body, class: "brand-button brand-button--brand" %>
        </div>
      </div>

      <nav aria-label="Writing page sections" class="mt-8 border border-white dark:border-black">
        <ol class="grid divide-y divide-white font-mono text-[11px] font-semibold uppercase tracking-[0.1em] dark:divide-black sm:grid-cols-4 sm:divide-x sm:divide-y-0">
          <% section_links.each do |number, label, href| %>
            <li>
              <%= link_to href, class: "flex items-center gap-3 px-4 py-4 text-zinc-300 hover:bg-brand hover:text-black dark:text-zinc-700" do %>
                <span><%= number %></span>
                <span><%= label %></span>
              <% end %>
            </li>
          <% end %>
        </ol>
      </nav>
    </div>
  </div>
</section>
