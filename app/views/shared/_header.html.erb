<header class="relative z-50 flex flex-none flex-col border-b border-black bg-white dark:border-white dark:bg-black" id="site-header">
  <div class="brand-container flex items-center justify-between gap-5 py-3">
    <%= link_to root_path, class: "font-mono text-xs font-semibold uppercase tracking-[0.14em] text-black dark:text-white" do %>
      <mark class="bg-brand px-1 text-black">[ST]</mark> <span class="text-zinc-500 dark:text-zinc-400">Angel Mora</span>
    <% end %>

    <nav class="hidden md:flex">
      <ul class="flex items-center text-xs font-semibold uppercase tracking-[0.08em] text-zinc-600 dark:text-zinc-300">
        <%= render NavLinkComponent.new(name: "About", href: about_path, current: current_page?(about_path)) %>
        <%= render NavLinkComponent.new(name: "Articles", href: articles_path, current: current_page?(articles_path)) %>
        <%= render NavLinkComponent.new(name: "Projects", href: projects_path, current: current_page?(projects_path)) %>
        <%= render NavLinkComponent.new(name: "Vault", href: vault_path, current: current_page?(vault_path)) %>
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <button type="button" class="hidden border-2 border-black bg-brand px-3 py-2 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-black transition hover:bg-brand-hover md:inline-flex" data-action="booking-modal#open" data-booking-modal-type-param="recruiter">Book a call</button>

      <div data-controller="theme">
        <button type="button" data-action="theme#toggle"
          data-theme-target="switch"
          class="theme-switch"
          role="switch"
          aria-label="Toggle color mode"
          aria-checked="false">
          <span class="theme-switch__label">Day</span>
          <span class="theme-switch__track"><span class="theme-switch__knob"></span></span>
          <span class="theme-switch__label">Night</span>
        </button>
      </div>

      <button type="button" data-action="mobile-menu#open"
        class="border-2 border-black bg-white px-3 py-2 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-black transition hover:bg-zinc-100 dark:border-white dark:bg-black dark:text-white dark:hover:bg-zinc-900 md:hidden">
        Menu
      </button>
    </div>
  </div>
</header>

<div id="mobile-menu" class="fixed inset-0 z-[60] hidden">
  <div id="mobile-menu-overlay" class="fixed inset-0 bg-black/60"></div>
  <div id="mobile-menu-panel" class="fixed inset-x-4 top-4 z-50 origin-top border-2 border-black bg-white p-6 dark:border-white dark:bg-black">
    <div class="flex flex-row-reverse items-center justify-between">
      <button type="button" data-action="mobile-menu#close" aria-label="Close menu" class="border border-black px-2 py-1 font-mono text-xs uppercase tracking-[0.1em] text-black dark:border-white dark:text-white">
        Close
      </button>
      <h2 class="font-mono text-xs font-semibold uppercase tracking-[0.12em] text-zinc-600 dark:text-zinc-400">Navigation</h2>
    </div>
    <nav class="mt-6">
      <ul class="-my-2 divide-y divide-zinc-300 font-mono text-sm uppercase tracking-[0.08em] text-black dark:divide-zinc-700 dark:text-white">
        <li><%= link_to "About", about_path, class: "block py-3 hover:underline decoration-brand decoration-2 underline-offset-4", data: { action: "mobile-menu#close" } %></li>
        <li><%= link_to "Articles", articles_path, class: "block py-3 hover:underline decoration-brand decoration-2 underline-offset-4", data: { action: "mobile-menu#close" } %></li>
        <li><%= link_to "Projects", projects_path, class: "block py-3 hover:underline decoration-brand decoration-2 underline-offset-4", data: { action: "mobile-menu#close" } %></li>
        <li><%= link_to "Vault", vault_path, class: "block py-3 hover:underline decoration-brand decoration-2 underline-offset-4", data: { action: "mobile-menu#close" } %></li>
        <li><button type="button" class="mt-4 block w-full border-2 border-black bg-brand px-3 py-3 text-center text-black" data-action="booking-modal#open mobile-menu#close" data-booking-modal-type-param="recruiter">Book a call</button></li>
      </ul>
    </nav>
  </div>
</div>
