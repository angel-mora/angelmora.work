<footer class="flex-none border-t border-black bg-white py-6 dark:border-white dark:bg-black">
  <div class="brand-container flex flex-col justify-between gap-4 text-xs sm:flex-row sm:items-center">
    <div class="font-mono font-semibold uppercase tracking-[0.12em] text-zinc-500 dark:text-zinc-400">
      Angel Mora - <%= spanish? ? "Ciudad de Mexico" : "Mexico City" %>
    </div>
    <div class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-xs uppercase tracking-[0.08em] text-black dark:text-white">
      <%= link_to "GitHub", "https://github.com/angel-mora", class: "hover:underline decoration-brand decoration-2 underline-offset-4" %>
      <%= link_to "LinkedIn", "https://linkedin.com/in/angelmoradev", class: "hover:underline decoration-brand decoration-2 underline-offset-4" %>
      <%= link_to "Email", "mailto:angelmomaa@gmail.com", class: "hover:underline decoration-brand decoration-2 underline-offset-4" %>
      <%= link_to "CV", "/angel_mora_cv.pdf", class: "hover:underline decoration-brand decoration-2 underline-offset-4" %>
      <%= link_to spanish? ? "EN" : "ES", localized_path(spanish? ? "en" : "es"), class: "hover:underline decoration-brand decoration-2 underline-offset-4" %>
    </div>
    <p class="font-mono text-xs uppercase tracking-[0.08em] text-zinc-500 dark:text-zinc-400">
      &copy; <%= Date.today.year %> - <%= spanish? ? "Ciudad de Mexico" : "Mexico City" %>
    </p>
  </div>
</footer>
